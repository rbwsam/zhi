{
  "name": "@rbwsam/zhi",
  "version": "1.0.1",
  "description": "Concurrent web crawler that detects slow pages, broken links, and unhealthy HTTP status codes across your site",
  "main": "dist/index.js",
  "bin": {
    "zhi": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "crawler",
    "health-check",
    "website"
  ],
  "author": "Sam Leavens",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rbwsam/zhi.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/cheerio": "^1.0.0",
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "chalk": "^5.6.2",
    "cheerio": "^1.2.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3"
  }
}
